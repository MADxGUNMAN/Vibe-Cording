# ===========================================
# Vibe Corder - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control!

# ===========================================
# Firebase Configuration
# ===========================================
# Get these from Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ===========================================
# AI API Keys
# ===========================================
# OpenRouter API Key - Get from https://openrouter.ai/keys
# Used for: GLM 4.5 Air, GPT OSS 120B, GPT OSS 20B
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Groq API Key - Get from https://console.groq.com/keys
# Used for: Llama 3.3 70B, Llama 3.1 8B
GROQ_API_KEY=gsk_your_groq_api_key_here

# ===========================================
# Optional: Admin Configuration
# ===========================================
# Admin emails are configured in src/lib/firestore.ts
# Admins get unlimited credits and bypass credit checks
